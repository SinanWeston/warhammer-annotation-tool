# Warhammer Analyzer Configuration
# Copy to .env and fill in at least one API key. Every other field has
# a sensible default.

# =============================================================================
# API KEYS (at least one required)
# =============================================================================

# OpenRouter — single key that grants access to Claude, GPT-4, Gemini,
# LLaMA, and many more. If set, it's used automatically for any provider
# whose native key is not configured, with the model id rewritten to
# OpenRouter's canonical prefix (e.g. claude-3-5-sonnet →
# anthropic/claude-3-5-sonnet). This is the simplest setup.
OPENROUTER_API_KEY=sk-or-v1-xxxxx

# Direct provider keys (optional — prefer native when available).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# =============================================================================
# ANALYZER — PASS 1: BBOX DETECTION
# =============================================================================

# Provider. One of: claude | openai | gemini | openrouter | llama
# Defaults to `openrouter` so the system works with just OPENROUTER_API_KEY.
DETECTION_PROVIDER=openrouter
DETECTION_MODEL=anthropic/claude-haiku-4-5

# Minimum confidence for accepting a detection (0.0-1.0).
DETECTION_CONFIDENCE=0.5

# Non-Maximum Suppression IoU threshold. Higher = more aggressive dedup.
NMS_IOU_THRESHOLD=0.5

# Bbox padding when cropping (0.0-1.0; 0.1 = 10%).
BBOX_PADDING=0.1

# =============================================================================
# ANALYZER — PASS 2: CLASSIFICATION (multi-tier cascade)
# =============================================================================

ENABLE_MULTI_TIER=true

# Tier 1: cheap screener. Accepts result if confidence >= threshold.
TIER1_PROVIDER=openrouter
TIER1_MODEL=google/gemini-2.5-flash-lite
TIER1_THRESHOLD=0.85

# Tier 2: accurate classifier.
TIER2_PROVIDER=openrouter
TIER2_MODEL=anthropic/claude-sonnet-4.5
TIER2_THRESHOLD=0.75

# Tier 3: premium arbiter. No escalation (final answer).
TIER3_PROVIDER=openrouter
TIER3_MODEL=openai/gpt-4o

# =============================================================================
# ANALYZER — PASS 3: TRIANGULATION
# =============================================================================

ENABLE_TRIANGULATION=true
VALIDATION_PROVIDER=openrouter
VALIDATION_MODEL=meta-llama/llama-3.2-90b-vision-instruct
TRIANGULATION_THRESHOLD=0.75

# =============================================================================
# LABELLING MODE (Phase 1 of ../STRATEGY.md)
# =============================================================================

LABELLING_ENABLED=true
LABELLING_CROPS_DIR=../scripts/phase1/crops
LABELLING_LABELS_CSV=../scripts/phase1/labels.csv
LABELLING_CHEATSHEET=../scripts/phase1/unit_slugs_cheatsheet.md
LABELLING_SUGGEST_PROVIDER=openrouter
LABELLING_SUGGEST_MODEL=anthropic/claude-sonnet-4.5

# =============================================================================
# SERVER
# =============================================================================

PORT=3002
FRONTEND_PORT=3003
NODE_ENV=development
LOG_LEVEL=info
MAX_UPLOAD_BYTES=52428800   # 50 MB

# =============================================================================
# OPTIONAL CLIP SERVICE (not wired into the labelling mode)
# =============================================================================

ENABLE_CLIP=false
CLIP_SERVICE_URL=http://localhost:8000
CLIP_DISAGREEMENT_THRESHOLD=0.80
