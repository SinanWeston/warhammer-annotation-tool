# Copy to .env and fill in values. Never commit .env.
# All vars are optional — defaults work for local single-user development.

# ═══════════════════════════════════════════════════════════
# Server
# ═══════════════════════════════════════════════════════════

# Backend port (default: 3001)
PORT=3001

# Node environment — affects logging and error detail
# Set to 'production' on deployed servers
NODE_ENV=development

# Optional HTTP Basic Auth password for multi-user ngrok deployments.
# When set, every request needs `Authorization: Basic <base64(user:PASSWORD)>`.
# Leave blank for local single-user work. See DEPLOY.md.
ANNOTATOR_PASSWORD=

# ═══════════════════════════════════════════════════════════
# YOLO inference (Python subprocess)
# ═══════════════════════════════════════════════════════════

# Absolute path to the trained YOLO model weights.
# Default: <repo>/runs/yolo11x_run2_best.pt
YOLO_MODEL_PATH=

# Absolute path to the Python interpreter with ultralytics installed.
# Default: <repo>/yolo_env/bin/python3
YOLO_PYTHON_PATH=

# Confidence threshold for /api/detect and annotation prediction.
# Higher = fewer boxes, fewer false positives. Default 0.25.
YOLO_INFERENCE_CONFIDENCE=0.25

# Confidence threshold used by active-learning batch scoring.
# Lower than inference so weakly-detected images still surface
# as "needs annotation". Default 0.10.
YOLO_BATCH_CONFIDENCE=0.10

# ═══════════════════════════════════════════════════════════
# Annotation data paths
# ═══════════════════════════════════════════════════════════

# Where to look for training images. Defaults to backend/training_data/.
# Override for running a second annotator instance against a different set.
TRAINING_DATA_PATH=

# Where to save/load annotation JSON files.
# Default: backend/training_data_annotations/
ANNOTATIONS_PATH=

# Where AI-generated bbox proposals live (DINO/YOLO).
# Default: backend/training_data_proposals/
PROPOSALS_PATH=

# Comma-separated list of source subdirectories to scan inside each
# faction folder. Default: reddit,dakkadakka
ANNOTATION_SOURCES=reddit,dakkadakka

# Target annotations per faction. Used for progress math.
# Default: 400
ANNOTATION_PER_FACTION_LIMIT=400
